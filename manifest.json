{
  "manifest_version": 3,
  "name": "Clipboard Cleaner",
  "version": "1.0",
  "description": "Remove caracteres especiais e limita a 255 caracteres automaticamente ao copiar.",
  "permissions": ["clipboardRead", "clipboardWrite", "notifications", "storage"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
